{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Swagger": {
    "Enabled": true
  },
  "VectorStore": {
    "Provider": "Qdrant",
    "Qdrant": {
      "Url": "http://localhost:6333",
      "CollectionName": "posts",
      "VectorSize": 1024
    }
  },
  "AWS": {
    "Region": "us-east-1",
    "EmbeddingModelId": "amazon.titan-embed-text-v2:0"
  }
}
