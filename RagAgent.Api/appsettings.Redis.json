{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "VectorStore": {
    "Provider": "Redis",
    "Redis": {
      "ConnectionString": "localhost:6379",
      "IndexName": "posts_idx",
      "VectorSize": "1024"
