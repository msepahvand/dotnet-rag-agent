<?xml version="1.0" encoding="utf-8"?>
<RuleSet Name="VectorSearch style rules" ToolsVersion="17.0">

  <Rules AnalyzerId="StyleCop.Analyzers" RuleNamespace="StyleCop.Analyzers">

    <!-- ── Layout rules (SA15xx) ────────────────────────────────────────── -->
    <!-- Braces must not be omitted from a single-line statement -->
    <Rule Id="SA1503" Action="Warning" />
    <!-- Opening brace must not be followed by a blank line -->
    <Rule Id="SA1505" Action="Warning" />
    <!-- Closing brace must not be preceded by a blank line -->
    <Rule Id="SA1508" Action="Warning" />
    <!-- Closing brace must be followed by blank line -->
    <Rule Id="SA1513" Action="Warning" />
    <!-- Single-line comments must not be followed by blank line -->
    <Rule Id="SA1512" Action="Warning" />

    <!-- ── Readability rules (SA11xx) ───────────────────────────────────── -->
    <!-- Parameters must begin on the line after the declaration header, or all on one line -->
    <Rule Id="SA1116" Action="Warning" />
    <!-- Parameters must all be on the same line or each on a separate line -->
    <Rule Id="SA1117" Action="Warning" />
    <!-- Parameter list must follow declaration -->
    <Rule Id="SA1111" Action="Warning" />

    <!-- ── Suppress everything else ─────────────────────────────────────── -->

    <!-- Documentation (all off) -->
    <Rule Id="SA1600" Action="None" />
    <Rule Id="SA1601" Action="None" />
    <Rule Id="SA1602" Action="None" />
    <Rule Id="SA1603" Action="None" />
